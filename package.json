{
  "name": "docflow",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=docflow",
    "deploy:preview": "npm run build && wrangler pages deploy dist --project-name=docflow --branch=preview",
    "pages:dev": "npm run build && wrangler pages dev dist --local",
    "kv:create": "wrangler kv namespace create DOCFLOW_KV",
    "kv:create:preview": "wrangler kv namespace create DOCFLOW_KV --preview"
  },
  "dependencies": {
    "@imgly/background-removal": "^1.4.5",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.0.0",
    "fuse.js": "^7.0.0",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.294.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-helmet-async": "^1.3.0",
    "react-router-dom": "^6.20.0",
    "tesseract.js": "^5.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260615.1",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "wrangler": "^3.17.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
